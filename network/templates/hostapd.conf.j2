interface=${HOTSPOT_IFACE}
driver=nl80211
ssid=${HOTSPOT_SSID}
hw_mode=g
channel=${HOTSPOT_CHAN}
ieee80211n=1
wmm_enabled=1
ht_capab=[HT40][SHORT-GI-20][DSSS_CCK-40]
macaddr_acl=0
auth_algs=1
ignore_broadcast_ssid=0
wpa=2
wpa_passphrase=${HOTSPOT_PASS}
wpa_key_mgmt=WPA-PSK
wpa_pairwise=TKIP
rsn_pairwise=CCMP
