#!/usr/bin/env bash
# Ghostlink CLI entry point

CONF="/etc/ghostlink/ghostlink.conf"
REPO="${GHOSTLINK_BASE:-/opt/ghostlink}"

source "$REPO/system/banner.sh" 2>/dev/null || true

cmd="${1:-}"
shift || true

case "$cmd" in
    status)
        bash "$REPO/identity/status.sh"
        ;;

    interfaces)
        sub="${1:-}"; shift || true
        case "$sub" in
            roles)  bash "$REPO/network/classify.sh" --map-only ;;
            *)      bash "$REPO/network/hw_inventory.sh" text ;;
        esac
        ;;

    mgmt)
        sub="${1:-status}"; shift || true
        case "$sub" in
            status)      bash "$REPO/network/mgmt.sh" status ;;
            keep)        bash "$REPO/network/mgmt.sh" keep ;;
            configure)   bash "$REPO/network/mgmt.sh" configure "$@" ;;
            reconnect)   bash "$REPO/network/mgmt.sh" reconnect ;;
            start)       bash "$REPO/network/mgmt.sh" start ;;
            *)           echo "Usage: ghostlink mgmt {status|keep|configure <ssid> [pass]|reconnect}" ;;
        esac
        ;;

    upstream)
        sub="${1:-status}"; shift || true
        case "$sub" in
            status)      bash "$REPO/network/upstream_mode.sh" status ;;
            monitor)     bash "$REPO/network/upstream_mode.sh" monitor ;;
            station)     bash "$REPO/network/upstream_mode.sh" station ;;
            managed)     bash "$REPO/network/upstream_mode.sh" station ;;
            connect)     bash "$REPO/network/upstream_mode.sh" connect "$@" ;;
            disconnect)  bash "$REPO/network/upstream_mode.sh" disconnect ;;
            *)           echo "Usage: ghostlink upstream {status|monitor|station|connect <ssid> [pass]|disconnect}" ;;
        esac
        ;;

    aux)
        sub="${1:-status}"; shift || true
        AUX_IFACE="gl-aux"
        case "$sub" in
            status)
                echo ""
                echo "  Auxiliary Interface ($AUX_IFACE / RTL8188EUS)"
                echo "  ─────────────────────────────────────────────"
                if ip link show "$AUX_IFACE" &>/dev/null; then
                    state=$(cat /sys/class/net/"$AUX_IFACE"/operstate 2>/dev/null || echo "unknown")
                    driver=$(basename "$(readlink -f "/sys/class/net/$AUX_IFACE/device/driver" 2>/dev/null)" 2>/dev/null || echo "n/a")
                    mac=$(cat /sys/class/net/"$AUX_IFACE"/address 2>/dev/null || echo "n/a")
                    echo "  Interface : $AUX_IFACE"
                    echo "  State     : $state"
                    echo "  Driver    : $driver"
                    echo "  MAC       : $mac"
                    # Check mode capabilities
                    phy=$(iw dev "$AUX_IFACE" info 2>/dev/null | awk '/wiphy/{print "phy"$2}')
                    if [[ -n "$phy" ]]; then
                        iw_out=$(iw phy "$phy" info 2>/dev/null || echo "")
                        echo "  Monitor   : $(echo "$iw_out" | grep -q 'monitor' && echo yes || echo no)"
                        echo "  AP mode   : $(echo "$iw_out" | grep -qE '\* AP$|\* AP ' && echo yes || echo no)"
                    fi
                    # Check fallback hotspot config
                    fallback=$(awk -F'=' '/^\[aux\]/{s=1} s && /^fallback_hotspot=/{print $2; exit}' "$CONF" 2>/dev/null || echo "false")
                    echo "  Fallback  : hotspot=$fallback"
                else
                    echo "  Interface : not found (RTL8188EUS adapter not plugged in)"
                    if lsusb 2>/dev/null | grep -qiE '2357:010c|0bda:8179|0bda:817[e8]'; then
                        echo "  USB       : RTL8188EUS detected — driver may not be loaded"
                        echo "  Tip       : modprobe 8188eu"
                    fi
                fi
                echo ""
                ;;
            monitor)
                if ! ip link show "$AUX_IFACE" &>/dev/null; then
                    echo "  [aux] $AUX_IFACE not found"; exit 1
                fi
                ip link set dev "$AUX_IFACE" down
                iw dev "$AUX_IFACE" set type monitor
                ip link set dev "$AUX_IFACE" up
                echo "  [aux] ✓ $AUX_IFACE → monitor mode"
                ;;
            station)
                if ! ip link show "$AUX_IFACE" &>/dev/null; then
                    echo "  [aux] $AUX_IFACE not found"; exit 1
                fi
                ip link set dev "$AUX_IFACE" down
                iw dev "$AUX_IFACE" set type managed
                ip link set dev "$AUX_IFACE" up
                echo "  [aux] ✓ $AUX_IFACE → station mode"
                ;;
            scan)
                if ! ip link show "$AUX_IFACE" &>/dev/null; then
                    echo "  [aux] $AUX_IFACE not found"; exit 1
                fi
                # Switch to monitor for scan
                ip link set dev "$AUX_IFACE" down 2>/dev/null || true
                iw dev "$AUX_IFACE" set type monitor 2>/dev/null || true
                ip link set dev "$AUX_IFACE" up
                "$REPO/venv/bin/python3" "$REPO/pentest/scan.py" "$AUX_IFACE" "$@"
                ;;
            *)
                echo "Usage: ghostlink aux {status|monitor|station|scan}" ;;
        esac
        ;;

    hotspot)
        sub="${1:-status}"; shift || true
        case "$sub" in
            start|on)    bash "$REPO/network/setup_hotspot.sh" ;;
            stop|off)    systemctl stop hostapd dnsmasq 2>/dev/null; echo "  [hotspot] stopped" ;;
            status)
                echo ""
                # Show which interface is being used (primary or fallback)
                if ip link show gl-hotspot &>/dev/null; then
                    echo "  Hotspot interface : gl-hotspot (RTL88x2BU — preferred)"
                elif ip link show gl-aux &>/dev/null; then
                    fallback=$(awk -F'=' '/^\[aux\]/{s=1} s && /^fallback_hotspot=/{print $2; exit}' "$CONF" 2>/dev/null || echo "false")
                    if [[ "$fallback" == "true" ]]; then
                        echo "  Hotspot interface : gl-aux (RTL8188EUS — fallback)"
                    else
                        echo "  Hotspot interface : none (gl-hotspot missing; fallback_hotspot=false)"
                    fi
                else
                    echo "  Hotspot interface : none (no hotspot-capable adapter found)"
                fi
                for svc in hostapd dnsmasq; do
                    state=$(systemctl is-active "$svc" 2>/dev/null || echo "inactive")
                    echo "  $svc : $state"
                done
                echo ""
                ;;
            configure)   bash "$REPO/network/setup_hotspot.sh" ;;
            *)           echo "Usage: ghostlink hotspot {start|stop|status}" ;;
        esac
        ;;

    nat)
        sub="${1:-status}"; shift || true
        case "$sub" in
            start|up|on)     bash "$REPO/network/nat.sh" up ;;
            stop|down|off)   bash "$REPO/network/nat.sh" down ;;
            status)          bash "$REPO/network/nat.sh" status ;;
            *)               echo "Usage: ghostlink nat {start|stop|status}" ;;
        esac
        ;;

    identity)
        sub="${1:-}"; shift || true
        # --iface <iface> selects operational target; default is gl-upstream
        _id_iface="gl-upstream"
        if [[ "${1:-}" == "--iface" ]]; then shift; _id_iface="${1:?'--iface requires interface name'}"; shift; fi
        case "$sub" in
            rotate)     bash "$REPO/identity/rotate.sh"  "$_id_iface" random ;;
            restore)    bash "$REPO/identity/restore.sh" "$_id_iface" ;;
            list)       jq -r 'keys[]' /etc/ghostlink/device_profiles.json ;;
            set)        bash "$REPO/identity/rotate.sh"  "$_id_iface" "${1:?'profile name required'}" ;;
            status)     bash "$REPO/identity/status.sh" ;;
            *)          bash "$REPO/identity/status.sh" ;;
        esac
        ;;

    repair)
        sub="${1:-}"; shift || true
        case "$sub" in
            hostname)
                MGMT_HOSTNAME=$(awk -F'=' '/^\[management\]/{s=1} s && /^hostname=/{print $2; exit}' "$CONF" 2>/dev/null || echo "Ghostlink")
                MGMT_HOSTNAME="${MGMT_HOSTNAME:-Ghostlink}"
                PREV_HOSTNAME=$(hostname 2>/dev/null || echo "")
                echo "  Repairing hostname: $PREV_HOSTNAME → $MGMT_HOSTNAME"
                hostnamectl set-hostname "$MGMT_HOSTNAME" 2>/dev/null || echo "$MGMT_HOSTNAME" > /etc/hostname
                if grep -qE '^127\.0\.1\.1' /etc/hosts 2>/dev/null; then
                    sed -i "s/^127\.0\.1\.1.*/127.0.1.1\t${MGMT_HOSTNAME}/" /etc/hosts
                else
                    printf '127.0.1.1\t%s\n' "$MGMT_HOSTNAME" >> /etc/hosts
                fi
                echo "  Hostname  : $(hostname)"
                echo "  /etc/hosts: $(grep '127.0.1.1' /etc/hosts)"
                ;;
            *)
                echo "Usage: ghostlink repair {hostname}"
                ;;
        esac
        ;;

    scan)
        sub="${1:-}"; shift || true
        case "$sub" in
            wifi|wifite)
                bash "$REPO/pentest/wifite_wrapper.sh" "$@"
                ;;
            ""|gl-*)
                iface="${sub:-gl-upstream}"
                # Fix: read uppercase MODE= key from upstream.state
                current_mode=$(grep -i '^MODE=' /var/lib/ghostlink/upstream.state 2>/dev/null | cut -d= -f2 | tr '[:upper:]' '[:lower:]' || echo "")
                if [[ "$current_mode" != "monitor" ]]; then
                    echo "  Switching gl-upstream to monitor mode..."
                    bash "$REPO/network/upstream_mode.sh" monitor
                fi
                "$REPO/venv/bin/python3" "$REPO/pentest/scan.py" "$iface" "$@"
                ;;
            *)
                iface="$sub"
                current_mode=$(grep -i '^MODE=' /var/lib/ghostlink/upstream.state 2>/dev/null | cut -d= -f2 | tr '[:upper:]' '[:lower:]' || echo "")
                if [[ "$current_mode" != "monitor" ]]; then
                    echo "  Switching gl-upstream to monitor mode..."
                    bash "$REPO/network/upstream_mode.sh" monitor
                fi
                "$REPO/venv/bin/python3" "$REPO/pentest/scan.py" "$iface" "$@"
                ;;
        esac
        ;;

    drivers)
        sub="${1:-status}"; shift || true
        case "$sub" in
            status)         bash "$REPO/network/drivers.sh" status ;;
            audit)          bash "$REPO/network/drivers.sh" audit ;;
            fix)
                target="${1:-}"; shift || true
                case "$target" in
                    rtl8812au) bash "$REPO/network/drivers.sh" fix-rtl8812au "$@" ;;
                    *)         echo "Usage: ghostlink drivers fix rtl8812au [--force]" ;;
                esac
                ;;
            monitor-test)   bash "$REPO/network/drivers.sh" monitor-test "${1:-}" ;;
            *)              echo "Usage: ghostlink drivers {status|audit|fix rtl8812au [--force]|monitor-test [iface]}" ;;
        esac
        ;;

    wifi)
        sub="${1:-doctor}"; shift || true
        case "$sub" in
            doctor) bash "$REPO/network/drivers.sh" wifi-doctor ;;
            *)      bash "$REPO/network/drivers.sh" wifi-doctor ;;
        esac
        ;;

    route)
        sub="${1:-status}"; shift || true
        case "$sub" in
            status) bash "$REPO/network/nat.sh" route-status ;;
            *)      echo "Usage: ghostlink route status" ;;
        esac
        ;;

    pentest)
        sub="${1:-}"; shift || true
        case "$sub" in
            start)  "$REPO/venv/bin/python3" "$REPO/pentest/engine.py" start "$@" ;;
            stop)   "$REPO/venv/bin/python3" "$REPO/pentest/engine.py" stop ;;
            report) cat "$(ls -t /var/log/ghostlink/reports/*.md 2>/dev/null | head -1)" ;;
            wifi)   bash "$REPO/pentest/wifite_wrapper.sh" "$@" ;;
            *)      echo "Usage: ghostlink pentest {start|stop|report|wifi [args]}" ;;
        esac
        ;;

    tools)
        bash "$REPO/network/tools_registry.sh" "${@:-list}"
        ;;

    update)
        bash "$REPO/install/update.sh" "$@"
        ;;

    version)
        echo ""
        _git_commit=$(git -C "$REPO" rev-parse --short HEAD 2>/dev/null || echo "unknown")
        _git_branch=$(git -C "$REPO" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")
        _git_remote=$(git -C "$REPO" remote get-url origin 2>/dev/null || echo "none")
        _install_path="$REPO"
        _conf_path="$CONF"
        _os_profile=$(cat /etc/ghostlink/.os_profile 2>/dev/null || echo "unknown")
        _last_update=""
        if [[ -f /var/lib/ghostlink/update.state ]]; then
            _last_update=$(grep '^LAST_UPDATE=' /var/lib/ghostlink/update.state | cut -d= -f2 || echo "")
        fi
        echo "  GhostLink Version Information"
        echo "  ──────────────────────────────────────────────────────"
        echo "  Git commit     : $_git_commit"
        echo "  Git branch     : $_git_branch"
        echo "  Git remote     : $_git_remote"
        echo "  Install path   : $_install_path"
        echo "  Config path    : /etc/ghostlink/ghostlink.conf"
        echo "  OS profile     : ${_os_profile:-unknown}"
        echo "  Last update    : ${_last_update:-(no update recorded)}"
        echo "  Symlink        : $(readlink -f /usr/local/bin/ghostlink 2>/dev/null || echo 'not installed')"
        echo ""
        ;;

    console)
        # Interactive GhostLink console
        bash "$REPO/system/banner.sh" 2>/dev/null || echo "  GhostLink Console"
        echo "  Type a command (without 'ghostlink'), or 'exit' to quit."
        echo "  Commands: status, doctor, interfaces, interfaces roles, tools, dashboard, exit"
        echo ""
        while true; do
            printf "ghostlink> "
            read -r _con_input || break
            [[ -z "$_con_input" ]] && continue
            [[ "$_con_input" == "exit" || "$_con_input" == "quit" ]] && echo "  Goodbye." && break
            [[ "$_con_input" == "help" ]] && _con_input="--help"
            # Re-execute ourselves with the input as arguments
            bash "$REPO/ghostlink" $_con_input
            echo ""
        done
        ;;

    dashboard)
        # Prefer management IP (gl-mgmt); fall back to first available IP
        _mgmt_actual=$(grep '^gl-mgmt=' /var/lib/ghostlink/interfaces.map 2>/dev/null | cut -d= -f2)
        [[ -z "$_mgmt_actual" ]] && { [[ -d /sys/class/net/gl-mgmt ]] && _mgmt_actual="gl-mgmt"; }
        _mgmt_ip=""
        if [[ -n "$_mgmt_actual" ]]; then
            _mgmt_ip=$(ip -4 addr show "$_mgmt_actual" 2>/dev/null | awk '/inet /{split($2,a,"/");print a[1];exit}')
        fi
        _bind_ip="${_mgmt_ip:-$(hostname -I | awk '{print $1}')}"
        _svc_state=$(systemctl is-active gl-dashboard 2>/dev/null) || _svc_state="inactive"
        echo ""
        echo "  Dashboard URL  : https://${_bind_ip}:8080"
        echo "  Service        : gl-dashboard (${_svc_state})"
        if [[ -z "$_mgmt_ip" ]]; then
            echo "  Warning        : management IP not found — URL may be unreachable from trusted network"
        fi
        echo ""
        ;;

    # Fix: update-tools now works because install/ is included in rsync
    update-tools)
        bash "$REPO/install/steps/07_tools.sh" "$REPO"
        ;;

    doctor)
        echo ""
        echo "  ── Interfaces ──────────────────────────────────────"
        for iface in gl-mgmt gl-upstream gl-hotspot gl-aux; do
            state=$(cat /sys/class/net/"$iface"/operstate 2>/dev/null || echo "missing")
            ip4=$(ip -4 addr show "$iface" 2>/dev/null | awk '/inet /{split($2,a,"/"); print a[1]; exit}')
            driver=$(basename "$(readlink -f "/sys/class/net/$iface/device/driver" 2>/dev/null)" 2>/dev/null || echo "n/a")
            ssid=$(iwgetid "$iface" -r 2>/dev/null || echo "")
            printf "  %-14s  state=%-8s  ip=%-16s  driver=%-10s  ssid=%s\n" \
                "$iface" "$state" "${ip4:-none}" "$driver" "${ssid:-(none)}"
        done
        echo ""
        echo "  ── Role map (/var/lib/ghostlink/interfaces.map) ─────"
        if [[ -f /var/lib/ghostlink/interfaces.map ]]; then
            sed 's/^/  /' /var/lib/ghostlink/interfaces.map
        else
            echo "  (not yet generated — run: ghostlink interfaces roles)"
        fi
        echo ""
        echo "  ── Management protection ────────────────────────────"
        source "$REPO/identity/mgmt_guard.sh" 2>/dev/null || true
        mgmt_protection_summary 2>/dev/null || echo "  (mgmt_guard.sh unavailable)"
        echo ""
        echo "  ── Services ─────────────────────────────────────────"
        for svc in ghostlink.target gl-system gl-network gl-identity gl-dashboard gl-fan hostapd dnsmasq; do
            state=$(systemctl is-active "$svc" 2>/dev/null || echo "inactive")
            printf "  %-24s  %s\n" "$svc" "$state"
        done
        echo ""
        echo "  ── Upstream state ───────────────────────────────────"
        sed 's/^/  /' /var/lib/ghostlink/upstream.state 2>/dev/null || echo "  (no state file)"
        echo ""
        echo "  ── NAT ──────────────────────────────────────────────"
        bash "$REPO/network/nat.sh" status 2>/dev/null || echo "  (nat.sh unavailable)"
        echo ""
        echo "  ── Drivers ──────────────────────────────────────────"
        for mod in 88XXau 88x2bu 8188eu brcmfmac; do
            if lsmod 2>/dev/null | grep -q "^${mod}[[:space:]]"; then
                echo "  $mod : loaded"
            else
                echo "  $mod : NOT loaded"
            fi
        done
        echo ""
        echo "  ── USB WiFi adapters ────────────────────────────────"
        lsusb 2>/dev/null | grep -iE "0bda|2357|realtek|tp-link" || echo "  (none detected)"
        echo ""
        ;;

    logs)
        journalctl -u 'gl-*' -f --no-pager
        ;;

    ""|--help|-h)
        echo "Usage: ghostlink <command> [subcommand] [args]"
        echo ""
        echo "  status                                System overview"
        echo "  interfaces                            Hardware WiFi inventory"
        echo "  interfaces roles                      Role assignment map"
        echo ""
        echo "  mgmt   status                         Management WiFi status"
        echo "  mgmt   keep                           Keep current gl-mgmt connection"
        echo "  mgmt   configure <ssid> [pass]        Connect gl-mgmt to WiFi"
        echo "  mgmt   reconnect                      Reconnect using saved config"
        echo ""
        echo "  upstream  status                      gl-upstream current state"
        echo "  upstream  monitor                     Switch to monitor mode"
        echo "  upstream  station                     Switch to managed/station mode"
        echo "  upstream  connect <ssid> [pass]       Connect to upstream WiFi"
        echo "  upstream  disconnect                  Disconnect upstream"
        echo ""
        echo "  aux       status                      RTL8188EUS auxiliary adapter status"
        echo "  aux       monitor                     Switch gl-aux to monitor mode"
        echo "  aux       station                     Switch gl-aux to managed mode"
        echo "  aux       scan                        Scan networks via gl-aux"
        echo ""
        echo "  hotspot   start                       Start distribution AP"
        echo "  hotspot   stop                        Stop distribution AP"
        echo "  hotspot   status                      Hotspot interface and service status"
        echo ""
        echo "  nat       start                       Apply NAT + policy routing rules"
        echo "  nat       stop                        Remove NAT rules"
        echo "  nat       status                      Show NAT + routing rule status"
        echo ""
        echo "  route     status                      Default/management/upstream route table + ip rules"
        echo ""
        echo "  drivers   status                      Driver/module/interface summary"
        echo "  drivers   audit                       Full RTL8812AU driver audit"
        echo "  drivers   fix rtl8812au [--force]     Fix/reinstall RTL8812AU DKMS driver"
        echo "  drivers   monitor-test [iface]        Safe monitor mode test (upstream/aux only)"
        echo "  wifi      doctor                      WiFi interface health check (all 4 roles)"
        echo ""
        echo "  tools     list                        Show all tools with install status"
        echo "  tools     info <tool>                 Show tool details and example commands"
        echo "  tools     run <tool> -- <args>        Run tool (native behavior preserved)"
        echo "  tools     doctor wifite               Check wifite prerequisites"
        echo ""
        echo "  scan [iface]                          Scan networks (auto monitor mode on gl-upstream)"
        echo "  scan wifi [args]                      Managed wifite launch (safety checks)"
        echo "  pentest  wifi [args]                  Managed wifite launch (safety checks)"
        echo "  pentest  [start|stop|report]          Pentest engine control"
        echo ""
        echo "  identity [status|rotate|restore|list|set <profile>] [--iface <iface>]"
        echo "  repair   hostname                     Restore configured management hostname"
        echo "  dashboard                             Print dashboard URL (prefers management IP)"
        echo "  doctor                                Diagnose interfaces, services, drivers"
        echo "  logs                                  Live system log stream"
        echo ""
        echo "  update   [--dry-run] [--force]        Pull and apply latest GhostLink"
        echo "  update-tools                          Update pentest tools only"
        echo "  version                               Show version, commit, install paths"
        echo "  console                               Interactive command console"
        ;;
    *)
        echo "Unknown command: $cmd  (run 'ghostlink --help')"
        exit 1
        ;;
esac
